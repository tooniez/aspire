# Polyglot SDK Validation - TypeScript
# This Dockerfile sets up an environment for validating the TypeScript AppHost SDK
#
# Usage:
#   docker build -f Dockerfile.typescript -t polyglot-typescript .
#   docker run --rm \
#     -v "$(pwd):/workspace" \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     polyglot-typescript
#
# Note: Expects self-extracting binary and NuGet artifacts to be pre-downloaded to /workspace/artifacts/
#
ARG NODE_VERSION=24
FROM mcr.microsoft.com/devcontainers/typescript-node:${NODE_VERSION}
ARG NODE_VERSION
ARG TSGO_VERSION=7.0.0-dev.20260523.1

# Ensure Yarn APT repository signing key is available (base image includes Yarn repo)
RUN curl -sS https://dl.yarnpkg.com/debian/pubkey.gpg | gpg --dearmor | sudo tee /etc/apt/keyrings/yarn-archive-keyring.gpg > /dev/null

# Install system dependencies and verify the MCR base image provides the requested Node.js runtime.
RUN case "$NODE_VERSION" in 22|24) ;; *) echo "Unsupported NODE_VERSION: $NODE_VERSION" >&2; exit 1 ;; esac && \
    apt-get update && apt-get install -y \
    wget \
    docker.io \
    jq \
    && node --version | grep -E "^v${NODE_VERSION}\\." \
    && rm -rf /var/lib/apt/lists/*

# TypeScript validation fixtures intentionally cover npm, pnpm, Yarn 4+, and Bun
# package-manager markers, so make all selected tools available in the image.
RUN corepack enable && \
    corepack prepare pnpm@10.0.0 --activate && \
    corepack prepare yarn@4.14.1 --activate && \
    npm install --global bun@1.2.0 "@typescript/native-preview@${TSGO_VERSION}" && \
    tsgo --version && \
    pnpm --version && \
    yarn --version && \
    bun --version

# Pre-configure Aspire CLI path
ENV PATH="/root/.aspire/bin:${PATH}"
ENV ASPIRE_CLI_TELEMETRY_OPTOUT=1

WORKDIR /workspace

COPY setup-local-cli.sh /scripts/setup-local-cli.sh
COPY test-typescript.sh /scripts/test-typescript.sh
COPY test-typescript-playground.sh /scripts/test-typescript-playground.sh
RUN chmod +x /scripts/setup-local-cli.sh /scripts/test-typescript.sh /scripts/test-typescript-playground.sh

# Entrypoint: Set up Aspire CLI and run validation
# Bundle extraction happens lazily on first command that needs the layout
ENTRYPOINT ["/bin/bash", "-c", "\
    set -e && \
    /scripts/setup-local-cli.sh && \
    /scripts/test-typescript.sh && \
    /scripts/test-typescript-playground.sh \
"]
