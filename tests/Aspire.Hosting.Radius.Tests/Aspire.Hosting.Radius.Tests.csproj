<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>$(DefaultTargetFramework)</TargetFramework>
    <!--
      ASPIRERADIUS002 (RadiusRecipe.Name) is intentionally surfaced as Experimental for end users
      to telegraph that named recipe selection is going away under Radius's UDT model. Tests need
      to exercise that property to cover the legacy/transition code paths in the publisher.
      ASPIRERADIUS003 marks the cloud-provider / cloud-managed-resource surface
      (WithAzureProvider/WithAwsProvider/WithManagedResource); ASPIRERADIUS004 marks the
      ConfigureRadiusInfrastructure escape hatch and the construct/options AST it exposes;
      ASPIRERADIUS057 marks WithContainerImage. Tests exercise all of these evolving APIs.
    -->
    <NoWarn>$(NoWarn);ASPIRERADIUS002;ASPIRERADIUS003;ASPIRERADIUS004;ASPIRERADIUS057</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Verify.XunitV3" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(TestsSharedDir)\TestModuleInitializer.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Aspire.Hosting.Radius\Aspire.Hosting.Radius.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.AppHost\Aspire.Hosting.AppHost.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.Redis\Aspire.Hosting.Redis.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.SqlServer\Aspire.Hosting.SqlServer.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.PostgreSQL\Aspire.Hosting.PostgreSQL.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.MongoDB\Aspire.Hosting.MongoDB.csproj" />
    <ProjectReference Include="..\..\src\Aspire.Hosting.RabbitMQ\Aspire.Hosting.RabbitMQ.csproj" />
    <ProjectReference Include="..\Aspire.Hosting.Tests\Aspire.Hosting.Tests.csproj" />
    <ProjectReference Include="..\Aspire.TestUtilities\Aspire.TestUtilities.csproj" />
  </ItemGroup>

</Project>
