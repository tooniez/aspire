<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- net10.0 (not DefaultTargetFramework=net8.0): references tools/SelectTests, which targets
         net10.0 for its Microsoft.Build ProjectGraph dependency, and loads that graph at runtime. -->
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsTestProject>true</IsTestProject>

    <!-- Run only on Linux in Github Actions -->
    <RunOnGithubActionsWindows>false</RunOnGithubActionsWindows>
    <RunOnGithubActionsMacOS>false</RunOnGithubActionsMacOS>

    <!-- Run only on Linux in Azdo Helix -->
    <RunOnAzdoHelixWindows>false</RunOnAzdoHelixWindows>
    <RunOnAzdoHelixLinux>false</RunOnAzdoHelixLinux>
  </PropertyGroup>

  <ItemGroup>
    <!-- Roslyn for compiling mock test assemblies -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" />
    <PackageReference Include="xunit.v3.extensibility.core" />
    <PackageReference Include="xunit.v3.assert" />
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aspire.TestUtilities\Aspire.TestUtilities.csproj" />
    <ProjectReference Include="..\..\tools\TypeScriptApiCompat\TypeScriptApiCompat.csproj" />
    <ProjectReference Include="..\..\tools\SelectTests\SelectTests.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(TestsSharedDir)TempDirectory.cs" Link="shared/TempDirectory.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\tools\GenerateCITimeline\GitHubApi.cs" Link="CITimeline\GitHubApi.cs" />
    <Compile Include="..\..\tools\GenerateCITimeline\TimelineRenderer.cs" Link="CITimeline\TimelineRenderer.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="CITimeline\TestData\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
