@using Aspire.Dashboard.Resources

@if (UnreadCount > 0)
{
    <FluentButton Class="header-button"
                  Appearance="Appearance.Stealth" OnClick="@HandleClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentCounterBadge Count="@UnreadCount"
                            Max="9"
                            ShowOverflow="true"
                            BackgroundColor="@Color.FillInverse"
                            Color="Color.Fill"
                            Appearance="Appearance.Accent"
                            Style="border: 0;">
            <ChildContent>
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Neutral" Style="vertical-align: bottom;" />
            </ChildContent>
        </FluentCounterBadge>
    </FluentButton>
}
else
{
    <FluentButton Class="header-button"
                  Appearance="Appearance.Stealth" OnClick="@HandleClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Neutral" />
    </FluentButton>
}
