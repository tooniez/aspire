      <trans-unit id="ContainerMountAnonymousVolumesReadOnlyExceptionMessage">
        <source>Anonymous volumes cannot be read-only.</source>
        <target state="translated">Los volúmenes anónimos no pueden ser de solo lectura.</target>
        <note />
      </trans-unit>
      <trans-unit id="ContainerMountBindMountsRequireRootedPaths">
        <source>Bind mounts must specify an absolute path.</source>
        <target state="translated">Los montajes de enlace deben especificar una ruta de acceso absoluta.</target>
        <note />
      </trans-unit>
      <trans-unit id="ContainerMountBindMountsRequireSourceExceptionMessage">
        <source>Bind mounts must specify a source path.</source>
        <target state="translated">Los montajes de enlace deben especificar una ruta de acceso de origen.</target>
        <note />
      </trans-unit>
      <trans-unit id="DcpDependencyCheckFailedMessage">
        <source>Application orchestrator dependency check returned an error: {0}</source>
        <target state="translated">La comprobación de dependencia del orquestador de aplicación devolvió un error: {0}</target>
        <note />
      </trans-unit>
      <trans-unit id="DcpVersionCheckTooLowMessage">
        <source>Newer version of the Aspire.Hosting.AppHost package is required to run the application. Ensure you are referencing at least version '{0}'.</source>
        <target state="translated">Se requiere una versión más reciente del paquete Deshoja.Hosting.AppHost para ejecutar la aplicación. Asegúrese de que hace referencia al menos a la versión "{0}".</target>
        <note />
      </trans-unit>
      <trans-unit id="InstallationInstructions">
        <source>Installation instructions</source>
        <target state="translated">Instrucciones de instalación</target>
        <note />
      </trans-unit>
      <trans-unit id="MissingCommandNotificationTitle">
        <source>Missing command</source>
        <target state="translated">Falta un comando</target>
        <note />
      </trans-unit>
      <trans-unit id="PersistentContainerWithoutUserSecrets">
        <source>Resource '{0}' has a persistent lifetime but the AppHost project does not have user secrets configured. Generated parameter values (such as passwords) may change on each restart, causing persistent containers to be recreated. Run 'aspire secret set' to initialize user secrets.</source>
        <target state="translated">El recurso "{0}" tiene una duración persistente, pero el proyecto AppHost no tiene secretos de usuario configurados. Los valores de parámetro generados (como las contraseñas) pueden cambiar en cada reinicio, lo que hace que se vuelvan a crear los contenedores persistentes. Ejecute "secret set" para inicializar los secretos de usuario.</target>
        <note />
      </trans-unit>
      <trans-unit id="RequiredCommandNotFound">
        <source>Required command '{0}' was not found on PATH or at the specified location.</source>
        <target state="translated">No se encontró el comando necesario "{0}" en PATH o en la ubicación especificada.</target>
        <note />
      </trans-unit>
      <trans-unit id="RequiredCommandNotFoundWithLink">
        <source>Required command '{0}' was not found on PATH or at the specified location. For installation instructions, see: {1}</source>
