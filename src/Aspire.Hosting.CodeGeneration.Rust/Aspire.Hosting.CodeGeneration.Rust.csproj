<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>$(DefaultTargetFramework)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Aspire.Hosting.CodeGeneration.Rust</RootNamespace>
    <!-- Required for Rust AppHost support -->
    <IsPackable>true</IsPackable>
    <!-- Code-generation infrastructure, not a discoverable polyglot integration, so opt out of the
         default 'polyglot' NuGet tag that `aspire add` uses to surface integrations to non-C# AppHosts. -->
    <IsAspirePolyglotCompatible>false</IsAspirePolyglotCompatible>
    <!-- No baseline exists since this package was previously not published -->
    <DisablePackageBaselineValidation>true</DisablePackageBaselineValidation>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="aspire" />
    <InternalsVisibleTo Include="Aspire.Hosting.CodeGeneration.Rust.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\transport.rs" LogicalName="Aspire.Hosting.CodeGeneration.Rust.Resources.transport.rs" />
    <EmbeddedResource Include="Resources\base.rs" LogicalName="Aspire.Hosting.CodeGeneration.Rust.Resources.base.rs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(SharedDir)Json\AtsJsonCodeWriter.cs" Link="AtsJsonCodeWriter.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aspire.TypeSystem\Aspire.TypeSystem.csproj" />
  </ItemGroup>

</Project>
