{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "out/test-e2e",
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "src/test-e2e/**/*.ts",
    "src/types/extensionApi.ts"
  ],
  "exclude": [
    "node_modules",
    ".test-artifacts",
    ".test-extensions",
    ".test-results",
    ".test-storage",
    ".test-workspaces",
    "dist"
  ]
}
