  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/aspire",
    "branch": "main"
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "compile-e2e": "node -e \"require('fs').rmSync('out/test-e2e',{recursive:true,force:true})\" && tsc -p tsconfig.e2e.json",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "lint": "eslint src",
    "unit-test": "vscode-test",
    "test": "yarn run unit-test",
    "pretest:e2e": "yarn run compile && yarn run compile-e2e",
    "test:e2e": "node scripts/run-e2e.js",
    "l10n:export": "gulp prepare",
    "l10n:import": "gulp localizationBundle",
    "generate-schema": "node scripts/generate-schema.js",
    "generate-version": "node scripts/generate-version.js",
    "precompile": "yarn run generate-version && yarn run generate-schema && yarn run l10n:export && yarn run l10n:import",
    "prepackage": "yarn run generate-version && yarn run generate-schema && yarn run l10n:export && yarn run l10n:import",
    "prewatch": "yarn run generate-version && yarn run generate-schema && yarn run l10n:export && yarn run l10n:import",
    "localize": "yarn run l10n:export && yarn run l10n:import"
  },
