    "jsonValidation": [
      {
        "fileMatch": "aspire.config.json",
        "url": "./schemas/aspire-config.schema.json"
      },
      {
        "fileMatch": ".aspire/settings.json",
        "url": "./schemas/aspire-settings.schema.json"
      },
      {
        "fileMatch": ".aspire/globalsettings.json",
        "url": "./schemas/aspire-global-settings.schema.json"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "aspire-vscode.runAppHostCommand",
          "when": "resourceFilename =~ /apphost\\.(cs|ts|mts|cts|js|mjs|cjs)$/i",
          "group": "aspire_actions@1"
        },
        {
          "command": "aspire-vscode.debugAppHostCommand",
          "when": "resourceFilename =~ /apphost\\.(cs|ts|mts|cts|js|mjs|cjs)$/i",
          "group": "aspire_actions@2"
        }
      ],
      "editor/title/run": [
        {
          "command": "aspire-vscode.runAppHostCommand",
          "when": "(aspire.fileIsAppHost || aspire.workspaceHasAppHost) && aspire.editorSupportsRunDebug",
          "group": "navigation@-4"
        },
        {
          "command": "aspire-vscode.debugAppHostCommand",
          "when": "(aspire.fileIsAppHost || aspire.workspaceHasAppHost) && aspire.editorSupportsRunDebug",
          "group": "navigation@-3"
        }
      ],
      "commandPalette": [
        {
          "command": "aspire-vscode.runAppHost",
          "when": "false"
        },
        {
          "command": "aspire-vscode.debugAppHost",
          "when": "false"
        },
        {
          "command": "aspire-vscode.runAppHostCommand",
          "when": "false"
        },
        {
          "command": "aspire-vscode.debugAppHostCommand",
          "when": "false"
        },
        {
          "command": "aspire-vscode.globalRefreshAppHosts",
          "when": "false"
        },
        {
          "command": "aspire-vscode.refreshAppHosts",
          "when": "false"
        },
        {
          "command": "aspire-vscode.openDashboard",
          "when": "!aspire.noRunningAppHosts"
        },
        {
          "command": "aspire-vscode.stopAppHost",
          "when": "false"
        },
        {
          "command": "aspire-vscode.openAppHostSource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.stopResource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.startResource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.restartResource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.viewResourceLogs",
          "when": "false"
        },
        {
          "command": "aspire-vscode.executeResourceCommand",
          "when": "false"
        },
        {
          "command": "aspire-vscode.executeResourceCommandItem",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensDebugPipelineStep",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensResourceAction",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensViewLogs",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensRevealResource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensOpenDashboard",
          "when": "false"
        },
        {
          "command": "aspire-vscode.codeLensViewAppHostLogs",
          "when": "false"
        },
        {
          "command": "aspire-vscode.switchToGlobalView",
          "when": "false"
        },
        {
          "command": "aspire-vscode.switchToWorkspaceView",
          "when": "false"
        },
        {
          "command": "aspire-vscode.copyEndpointUrl",
          "when": "false"
        },
        {
          "command": "aspire-vscode.openInExternalBrowser",
          "when": "false"
        },
        {
          "command": "aspire-vscode.openInIntegratedBrowser",
          "when": "false"
        },
        {
          "command": "aspire-vscode.copyAppHostPath",
          "when": "false"
        },
        {
          "command": "aspire-vscode.copyResourceName",
          "when": "false"
        },
        {
          "command": "aspire-vscode.viewAppHostSource",
          "when": "false"
        },
        {
          "command": "aspire-vscode.expandAll",
          "when": "false"
        },
        {
          "command": "aspire-vscode.viewAppHostLogFile",
          "when": "false"
        },
        {
          "command": "aspire-vscode.copyLogFilePath",
          "when": "false"
        },
        {
          "command": "aspire-vscode.openDashboardToSide",
          "when": "!aspire.noRunningAppHosts"
        }
      ],
      "view/title": [
        {
          "command": "aspire-vscode.switchToGlobalView",
          "when": "view == 'aspire-vscode.appHosts' && aspire.viewMode != 'global'",
          "group": "navigation"
        },
        {
          "command": "aspire-vscode.switchToWorkspaceView",
          "when": "view == 'aspire-vscode.appHosts' && aspire.viewMode == 'global'",
          "group": "navigation"
        },
        {
          "command": "aspire-vscode.globalRefreshAppHosts",
          "when": "view == 'aspire-vscode.appHosts' && aspire.viewMode == 'global'",
          "group": "navigation"
        },
        {
          "command": "aspire-vscode.refreshAppHosts",
          "when": "view == 'aspire-vscode.appHosts' && aspire.viewMode != 'global'",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aspire-vscode.openDashboard",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?$|workspaceResources(:|$))/",
          "group": "inline"
        },
        {
          "command": "aspire-vscode.openDashboardToSide",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?$|workspaceResources(:|$))/",
          "group": "inline"
        },
        {
          "command": "aspire-vscode.expandAll",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?$|workspaceResources(:|$))/",
          "group": "inline"
        },
        {
          "command": "aspire-vscode.openAppHostSource",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?|workspaceResources(:hasAppHost|:stopping)?|workspaceAppHost(Launching|Stopping)?)$/",
          "group": "1_open@1"
        },
        {
          "command": "aspire-vscode.runAppHost",
          "when": "view == aspire-vscode.appHosts && viewItem == workspaceAppHost",
          "group": "2_actions@1"
        },
        {
          "command": "aspire-vscode.debugAppHost",
          "when": "view == aspire-vscode.appHosts && viewItem == workspaceAppHost",
          "group": "2_actions@2"
        },
        {
          "command": "aspire-vscode.stopAppHost",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost$|workspaceResources:hasAppHost)$/",
          "group": "2_actions@1"
        },
        {
          "command": "aspire-vscode.copyAppHostPath",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?|workspaceResources(:hasAppHost|:stopping)?|workspaceAppHost(Launching|Stopping)?)$/",
          "group": "3_clipboard@1"
        },
        {
          "command": "aspire-vscode.stopResource",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource.*:canStop/",
          "group": "2_actions@1"
        },
        {
          "command": "aspire-vscode.startResource",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource.*:canStart/",
          "group": "2_actions@2"
        },
        {
          "command": "aspire-vscode.restartResource",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource.*:canRestart/",
          "group": "2_actions@3"
        },
        {
          "command": "aspire-vscode.executeResourceCommand",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource(:|$)/",
          "group": "2_actions@4"
        },
        {
          "command": "aspire-vscode.executeResourceCommandItem",
          "when": "view == aspire-vscode.appHosts && viewItem == resourceCommand:enabled",
          "group": "2_actions@4"
        },
        {
          "command": "aspire-vscode.viewResourceLogs",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource(:|$)/",
          "group": "3_info@1"
        },
        {
          "command": "aspire-vscode.openInExternalBrowser",
          "when": "view == aspire-vscode.appHosts && viewItem == endpointUrl",
          "group": "1_open@1"
        },
        {
          "command": "aspire-vscode.openInIntegratedBrowser",
          "when": "view == aspire-vscode.appHosts && viewItem == endpointUrl",
          "group": "1_open@2"
        },
        {
          "command": "aspire-vscode.copyEndpointUrl",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^endpointUrl/",
          "group": "3_clipboard@1"
        },
        {
          "command": "aspire-vscode.copyResourceName",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^resource(:|$)/",
          "group": "3_info@2"
        },
        {
          "command": "aspire-vscode.viewAppHostSource",
          "when": "view == aspire-vscode.appHosts && viewItem =~ /^(appHost(:stopping)?|workspaceResources(:hasAppHost|:stopping))$/",
          "group": "1_open@2"
        },
        {
          "command": "aspire-vscode.viewAppHostLogFile",
          "when": "view == aspire-vscode.appHosts && viewItem == logFileItem",
          "group": "1_open@1"
        },
        {
          "command": "aspire-vscode.copyLogFilePath",
          "when": "view == aspire-vscode.appHosts && viewItem == logFileItem",
          "group": "3_clipboard@1"
        }
      ]
    },
    "colors": [
      {
        "id": "aspire.brandPurple",
